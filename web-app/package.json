{
  "name": "two-princesses-game",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:electron": "vite build --base ./",
    "lint": "eslint .",
    "preview": "vite preview",
    "pack:mac": "npm run build:electron && electron-builder --mac dir",
    "dist:mac": "npm run build:electron && electron-builder --mac",
    "pack:win": "npm run build:electron && electron-builder --win portable",
    "dist:win": "npm run build:electron && electron-builder --win"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.twoprincesses.game",
    "productName": "The Two Princesses",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ]
    }
  }
}
